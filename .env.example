# Local PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgresql://dreamcatcher:dreamcatcher@localhost:5433/dreamcatcher

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-random-secret-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# Google Cloud OAuth web application credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated and checked case-insensitively. Keep this to exactly two emails.
AUTH_ALLOWED_EMAILS=you@example.com,her@example.com

# OpenAI API
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
